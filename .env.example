# Backend — copy to .env and adjust

# Use mock AI fixtures locally (no Anthropic API key required)
MOCK_AI=true

# Required when MOCK_AI is not true
# ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

PORT=3001

# Comma-separated allowed browser origins (default: localhost:5173)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
